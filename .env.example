# Copy to .env and adjust. All variables use the CA_ prefix; nested settings
# use a double underscore (e.g. CA_AI__DEFAULT_PROVIDER).

CA_ENVIRONMENT=development
CA_LOG_LEVEL=INFO
CA_LOG_JSON=false

# Output of generated documentation
CA_SCAN__DEFAULT_OUT=./docs-output
CA_SCAN__STATIC_ONLY=false

# AI (optional — leave default_provider unset / use --static-only to skip AI)
CA_AI__DEFAULT_PROVIDER=claude
CA_AI__BUDGET_PER_SCAN_USD=2.0
ANTHROPIC_API_KEY=

# Optional capabilities
CA_GIT__ENABLED=true

# Persistence (only needed for API/workers, F6+)
# CA_DATABASE_URL=postgresql+psycopg://architect:architect@localhost:5432/architect
# CA_REDIS_URL=redis://localhost:6379/0
