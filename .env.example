# Copy to .env and adjust. All variables use the CA_ prefix; nested settings
# use a double underscore (e.g. CA_AI__DEFAULT_PROVIDER).

CA_ENVIRONMENT=development
CA_LOG_LEVEL=INFO
CA_LOG_JSON=false

# Docker only: where the API publishes on the host. BIND_ADDR is the interface
# (default 127.0.0.1, host-only). For a "everything over the tailnet by IP:port"
# setup, set it to this host's Tailscale IP so the dashboard is reachable at
# http://<tailscale-ip>:47800/ from any device on the tailnet — and nowhere else.
# Do NOT use 0.0.0.0 unless you intend to expose it to the public internet.
# BIND_ADDR=100.83.238.95
# HOST_PORT=47800

# Output of generated documentation
CA_SCAN__DEFAULT_OUT=./docs-output
CA_SCAN__STATIC_ONLY=false

# AI (optional — use --static-only to skip the AI pass entirely).
# Providers: claude | openai | openrouter | gemini | local (or a plugin name).
CA_AI__DEFAULT_PROVIDER=claude
CA_AI__BUDGET_PER_SCAN_USD=2.0
CA_AI__MAX_TOKENS=4096
# Cache AI narratives so re-scanning an unchanged codebase skips the model call
CA_AI__CACHE_ENABLED=true

# Provider credentials / models (only the selected provider's vars are needed)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# CA_OPENAI_MODEL=gpt-4o-mini
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
# CA_GEMINI_MODEL=gemini-1.5-flash
# Local OpenAI-compatible server (e.g. Ollama); no API key required
# CA_LOCAL_ENDPOINT=http://localhost:11434/v1
# CA_LOCAL_MODEL=llama3

# Remote CLI runner: use an already-authenticated Claude/Codex CLI on another
# machine (e.g. a Mac on your tailnet) — no provider API key, no local model.
# Start the runner from tools/cli_runner (see its README), then:
# CA_AI__DEFAULT_PROVIDER=cli_runner
# CA_CLI_RUNNER__BASE_URL=http://100.83.238.95:8787   # the Mac's Tailscale IP
# CA_CLI_RUNNER__AGENT=claude                          # claude | codex
# CA_CLI_RUNNER__TIMEOUT_SECONDS=600
# CA_CLI_RUNNER__SHARED_SECRET=                        # must match the runner's
# CA_CLI_RUNNER__WORKING_DIR=                          # optional path on the runner

# Optional capabilities
CA_GIT__ENABLED=true

# Persistence (only needed for API/workers, F6+)
# CA_DATABASE_URL=postgresql+psycopg://architect:architect@localhost:5432/architect
# CA_REDIS_URL=redis://localhost:6379/0
