# ==========================================================================
# Git Architect — STACK variables for Portainer (deploy from GHCR).
# Copy these into the stack's variables editor (or a .env). NEVER commit the
# real .env to the repo.
# ==========================================================================

# --- Image published on GHCR ---
# Tag to deploy. Use a fixed version (1.0.0) in prod; "dev"/"latest" for rolling.
IMAGE_TAG=1.0.0

# --- Networking ---
# BIND_ADDR = this host's Tailscale IP -> reachable ONLY from the tailnet.
# Use 0.0.0.0 to expose it to LAN/Internet.
BIND_ADDR=100.83.238.95
# Host port on the VPS (loopback/tailnet). Use a FREE one — 8088 and 48080 are taken.
HOST_PORT=8082
# Port the app listens on INSIDE the container (the image's default is 47800).
CONTAINER_PORT=47800

# --- AI (optional) ---
# Without a key, scans run static-only (no AI narrative).
# Providers: claude | openai | openrouter | gemini | local (or a plugin name).
CA_AI__DEFAULT_PROVIDER=claude
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# GOOGLE_API_KEY=
